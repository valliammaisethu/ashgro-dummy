{
  "name": "ashgrow-super-admin-web",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/browser": "^9.22.0",
    "@sentry/react": "^9.22.0",
    "@sentry/replay": "^7.116.0",
    "@sentry/tracing": "^7.120.3",
    "@stripe/react-stripe-js": "^3.7.0",
    "@stripe/stripe-js": "^7.3.0",
    "@tanstack/react-query": "^5.79.0",
    "antd": "^5.25.1",
    "axios": "^1.6.2",
    "class-transformer": "^0.5.1",
    "clsx": "^2.1.1",
    "country-state-city": "^3.2.1",
    "dayjs": "^1.11.11",
    "formik": "^2.4.5",
    "hammerjs": "^2.0.8",
    "history": "^5.3.0",
    "libphonenumber-js": "^1.12.8",
    "lodash": "^4.17.21",
    "pdfjs-dist": "^5.3.31",
    "postcode-validator": "^3.10.5",
    "query-string": "^9.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.56.4",
    "react-otp-input": "^3.1.0",
    "react-router-dom": "^6.20.1",
    "reflect-metadata": "^0.2.2",
    "sass": "^1.69.5",
    "serializr": "^3.0.5",
    "yup": "^1.6.1"
  },
  "scripts": {
    "start": "vite",
    "start:staging": "vite --mode staging",
    "start:production": "env-cmd -f .env.production react-scripts start",
    "build": "tsc && NODE_OPTIONS='--max-old-space-size=2048' vite build",
    "build:staging": "env-cmd -f .env.staging react-scripts build",
    "build:production": "env-cmd -f .env.production react-scripts build",
    "test": "vitest",
    "eject": "react-scripts eject",
    "storybook": "storybook dev",
    "build-storybook": "storybook build -s public",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "prepare": "husky"
  },
  "eslintConfig": {
    "extends": "react-app",
    "overrides": [
      {
        "files": [
          "**/*.stories.*"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      }
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npm run lint:fix",
      "eslint --cache --fix"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@bbbtech/storybook-formik": "^3.0.0",
    "@storybook/addon-actions": "^7.6.3",
    "@storybook/addon-essentials": "^7.6.3",
    "@storybook/addon-interactions": "^7.6.3",
    "@storybook/addon-links": "^7.6.3",
    "@storybook/addon-mdx-gfm": "^7.6.3",
    "@storybook/cli": "^7.6.3",
    "@storybook/node-logger": "^7.6.3",
    "@storybook/preset-create-react-app": "^7.6.3",
    "@storybook/react": "^7.6.3",
    "@storybook/react-webpack5": "^7.6.3",
    "@storybook/testing-library": "^0.2.2",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.3",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@types/react-router-dom": "^5.3.3",
    "@types/storybook-react-router": "^1.0.6",
    "@types/yup": "^0.29.14",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-plugin-named-exports-order": "^0.0.2",
    "env-cmd": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "happy-dom": "^17.6.3",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^16.1.0",
    "msw": "^2.7.3",
    "prettier": "^3.5.3",
    "prop-types": "^15.8.1",
    "storybook": "^7.6.3",
    "storybook-addon-react-router-v6": "^2.0.10",
    "vite": "^7.1.7",
    "vite-plugin-svgr": "^4.2.0",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^3.2.4",
    "webpack": "^5.89.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
